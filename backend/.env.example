# MongoDB Atlas or local MongoDB connection
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/agentpulse

SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Used only once to seed the first admin when no admin exists in MongoDB.
# After creation, admin login is verified from the users collection.
ADMIN_NAME=Platform Admin
ADMIN_PHONE=YOUR_ADMIN_PHONE
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

PORT=3000
